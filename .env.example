# ── Recipe Cleanse — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── AI Backend ────────────────────────────────────────────────────────────────
# "groq" (default, generous free tier) | "openai" | "google"
AI_BACKEND=groq

# Groq — free at console.groq.com (~14,400 req/day free)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI — only needed if AI_BACKEND=openai
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini — only needed if AI_BACKEND=google
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.0-flash-lite
