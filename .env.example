# ── Recipe Cleanse — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── AI Backend ────────────────────────────────────────────────────────────────
# Choose "google" (Vercel / production) or "ollama" (local dev, free)
AI_BACKEND=google

# Google Gemini — free key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.0-flash-exp

# Ollama — only needed if AI_BACKEND=ollama
# Install: https://ollama.ai  |  Pull model: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
